#include <iostream>
#include <vector>
#include <queue>

using namespace std;

int main()
{
    vector<vector<int>> graph;
    vector<int> result;
    vector<int> inDegree;
    queue<int> q;

    int n, m;
    cin >> n >> m;
    graph.resize(n + 1);
    inDegree.resize(n + 1, 0);
    for (int i = 0; i < m; i++)
    {
        int u, v;
        cin >> u >> v;
        graph[u].push_back(v);
    }

    for (int i = 1; i <= n; i++)
        if (graph[i].empty())
            q.push(i);

    for (int i = 1; i <= n; i++)
    {
        if (q.empty())
            return 0;
        int x = q.front();
        q.pop();
        result.push_back(x);
        for (int j = 0; j < graph[x].size(); j++)
        {
            int y = graph[x][j];
            if (--inDegree[y] == 0)
                q.push(y);
        }
    }

    for (int i = 1; i <= n; i++)
        cout << result[i] << " ";

    return 0;
}
